{
    "cmake.sourceDirectory": "${workspaceFolder}/cuda-cmake",
    "cmake.buildDirectory": "${workspaceFolder}/cuda-cmake/build-ninja-${buildType}",
    "files.associations": {
        "*.cu": "cuda-cpp",
        "*.cuh": "cuda-cpp"
    },
    "C_Cpp.default.includePath": [
        "${workspaceFolder}/common"
    ],
    "C_Cpp.default.defines": [
        "__CUDACC__"
    ],
    "files.exclude": {
        "**/build-*": true,
        "**/.cache": true
    },
    "search.exclude": {
        "**/build-*": true,
        "**/compile_commands.json": true
    },
    "editor.formatOnSave": true,
    "editor.tabSize": 4,
    "[powershell]": {
        "editor.tabSize": 2
    }
}
